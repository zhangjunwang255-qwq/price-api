# price-api/.env.example
# 复制为 .env 后填入实际值

# ── 快期账号（必填）────────────────────────────────
TQ_USER=
TQ_PASS=

# ── MySQL ───────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=price_api
MYSQL_PASSWORD=
MYSQL_DATABASE=price_history

# ── 服务 ────────────────────────────────────────────
PORT=7860
LOG_LEVEL=INFO
